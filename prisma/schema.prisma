generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String  @id @default(cuid())
  name      String  @unique
  apodo     String?
  email     String  @unique
  gender    String?
  password  String
  modelName String?

  createdAt DateTime @default(now())
  Tarea     Tarea[]
  Docs      Docs[]
}

model Tarea {
  id        Int      @id @default(autoincrement())
  userId    String
  title     String
  hour      String
  day       Int
  month     Int
  year      Int
  desc      String?
  baseID    String   @unique
  context   Json
  generated String?
  number    Int?
  createdAt DateTime @default(now())

  relationUser Usuario @relation(fields: [userId], references: [id])
}

model Docs {
  id        Int      @id @default(autoincrement())
  userID    String
  title     String?
  content   String?
  createdAt DateTime @default(now())

  relationUser Usuario @relation(fields: [userID], references: [id])
}
