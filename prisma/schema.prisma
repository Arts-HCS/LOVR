generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         String  @id @default(cuid())
  name       String  @unique
  apodo      String?
  email      String  @unique
  gender     String?
  password   String
  modelName  String?
  modelRules String?
  modelID    String?

  createdAt     DateTime        @default(now())
  Tarea         Tarea[]
  Docs          Docs[]
  StyleRulebook StyleRulebook[]
}

model Tarea {
  id              Int      @id @default(autoincrement())
  userId          String
  title           String
  hour            String
  day             Int
  month           Int
  year            Int
  desc            String?
  baseID          String   @unique
  context         Json
  generated       String?
  lovrGenerated   String?
  slidesGenerated Json?
  createdAt       DateTime @default(now())

  relationUser Usuario @relation(fields: [userId], references: [id])
}

model Docs {
  id        Int      @id @default(autoincrement())
  userID    String
  title     String?
  content   String?
  createdAt DateTime @default(now())

  relationUser Usuario @relation(fields: [userID], references: [id])
}

model StyleRulebook {
  id        Int      @id @default(autoincrement())
  userId    String
  label     String
  modelUsed String
  modelID   String   @unique @default(cuid())
  rules     String
  desc      String?
  createdAt DateTime @default(now())

  relationUser Usuario @relation(fields: [userId], references: [id])
}
